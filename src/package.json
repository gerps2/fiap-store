{
  "name": "fiap-mf-aula1",
  "version": "0.0.0",
  "description": "FIAP PosTech - Arquitetura Angular para Aplicacoes de Alta Escala - Aula 1 - Esqueleto MFE com Native Federation",
  "scripts": {
    "ng": "ng",
    "start": "concurrently \"npm run start:produtos\" \"npm run start:carrinho\" \"npm run start:checkout\" \"npm run start:host\"",
    "start:host": "ng serve host --port 4200 --open",
    "start:produtos": "ng serve mfe-produtos --port 4201",
    "start:carrinho": "ng serve mfe-carrinho --port 4202",
    "start:checkout": "ng serve mfe-checkout --port 4203",
    "build": "ng build",
    "build:all": "ng build host && ng build mfe-produtos && ng build mfe-carrinho && ng build mfe-checkout"
  },
  "private": true,
  "dependencies": {
    "@angular-architects/native-federation": "^21.2.3",
    "@angular/animations": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@softarc/native-federation-node": "^3.3.4",
    "es-module-shims": "^1.5.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "typescript": "~5.9.2"
  }
}
