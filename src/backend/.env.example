# === Runtime ===
PORT=3000
NODE_ENV=development

# === Database (SQLite file) ===
DATABASE_PATH=./db.sqlite

# === JWT (ES256) ===
# Gerar com: npm run gen:keys
# Chaves são escritas em .keys/ e os paths abaixo apontam pra elas.
JWT_ISSUER=fiap-store
JWT_AUDIENCE=fiap-store-frontend
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_PRIVATE_KEY_PATH=./.keys/es256-private.pem
JWT_PUBLIC_KEY_PATH=./.keys/es256-public.pem

# === CORS ===
CORS_ORIGIN=http://localhost:4200

# === CSRF ===
CSRF_COOKIE_NAME=csrf_token
