{
  "name": "@fiap-store/frontend",
  "version": "0.0.0",
  "description": "FIAP PosTech - Arquitetura Angular para Aplicacoes de Alta Escala - Frontend (host + MFEs + shared libs)",
  "scripts": {
    "ng": "ng",
    "manifest:local": "node ../../scripts/use-manifest.mjs local",
    "manifest:dev": "node ../../scripts/use-manifest.mjs dev",
    "manifest:solo": "node ../../scripts/use-manifest.mjs solo",
    "prestart": "npm run manifest:local",
    "start": "concurrently \"npm run start:produtos\" \"npm run start:carrinho\" \"npm run start:checkout\" \"npm run start:notificacoes\" \"npm run start:host\"",
    "prestart:local": "npm run manifest:local",
    "start:local": "npm run start",
    "prestart:solo": "npm run manifest:solo --",
    "start:solo": "cross-var ng serve $npm_config_mfe --port $npm_config_port",
    "start:host": "ng serve host --port 4200 --open",
    "start:produtos": "ng serve mfe-produtos --port 4201",
    "start:carrinho": "ng serve mfe-carrinho --port 4202",
    "start:checkout": "ng serve mfe-checkout --port 4203",
    "start:notificacoes": "ng serve mfe-notificacoes --port 4204",
    "build": "ng build",
    "build:shared-ui": "ng build shared-ui",
    "build:all": "npm run build:shared-ui && ng build host && ng build mfe-produtos && ng build mfe-carrinho && ng build mfe-checkout && ng build mfe-notificacoes"
  },
  "private": true,
  "dependencies": {
    "@angular-architects/native-federation": "^21.2.3",
    "@angular/animations": "^21.2.0",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@apollo/client": "^3.14.1",
    "@softarc/native-federation-node": "^3.3.4",
    "apollo-angular": "^8.0.2",
    "es-module-shims": "^1.5.12",
    "graphql": "^16.13.2",
    "graphql-ws": "^6.0.8",
    "rxjs": "~7.8.0",
    "socket.io-client": "^4.8.3",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.7",
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@graphql-tools/merge": "^9.1.8",
    "@graphql-tools/schema": "^10.0.32",
    "@graphql-tools/utils": "^11.0.1",
    "concurrently": "^9.0.0",
    "crossws": "^0.4.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "relay-runtime": "^20.1.1",
    "typescript": "~5.9.2"
  }
}
